# Required
DATABASE_URL=postgres://bootnode:CHANGEME@127.0.0.1:5432/bootnode
BOOTNODE_UPSTREAM_RPC_URL=https://soroban-testnet.stellar.org

# HTTPS / ACME
BOOTNODE_BIND=0.0.0.0:443
BOOTNODE_DOMAIN=bootnode.example.com
BOOTNODE_ACME_EMAIL=admin@example.com
BOOTNODE_ACME_CACHE_DIR=/var/lib/stellar-bootnode/acme-cache
# Optional (LetsEncrypt staging):
# BOOTNODE_ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory

# Rate limiting
BOOTNODE_RATE_LIMIT_RPS=10
BOOTNODE_RATE_LIMIT_BURST=20

# Redirect policy
BOOTNODE_REDIRECT_DAYS=5
BOOTNODE_LEDGER_SECONDS=5

# OpenTelemetry (optional)
BOOTNODE_OTEL_ENABLED=0
# BOOTNODE_OTEL_OTLP_ENDPOINT=http://otel-collector:4317
# BOOTNODE_OTEL_SERVICE_NAME=poolstellar-bootnode
# BOOTNODE_OTEL_SAMPLE_RATIO=0.05

